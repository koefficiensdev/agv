using System;
using System.Collections.Generic;
using System.Linq;
using System.Runtime.InteropServices;
using System.Text;
using System.Threading;

namespace AgvReconnectOnly
{
    internal static class Program
    {
        private const string WifiProfileName = "SAJAT_WIFI_PROFIL";
        private const string TargetSsid = "SAJAT_SSID";

        private static readonly string[] AllowedBssids =
        {
            "AA:BB:CC:11:22:33",
            "AA:BB:CC:11:22:44",
            "AA:BB:CC:11:22:55"
        };

        private const int LoopDelayMs = 2000;
        private const int RetryDelayMs = 3000;
        private const int MinRssiToUse = -85;

        private static HashSet<string> _allowed = null!;

        static void Main()
        {
            _allowed = new HashSet<string>(
                AllowedBssids.Select(NormalizeMac),
                StringComparer.OrdinalIgnoreCase);

            uint negotiatedVersion;
            IntPtr clientHandle;
            ThrowIfError(WlanOpenHandle(2, IntPtr.Zero, out negotiatedVersion, out clientHandle), "WlanOpenHandle");

            try
            {
                var iface = GetFirstWifiInterface(clientHandle);

                Console.WriteLine($"Interface: {iface.strInterfaceDescription}");
                Console.WriteLine("AGV reconnect-only watcher elindult...");

                while (true)
                {
                    try
                    {
                        if (IsConnectedToTargetWifi(clientHandle, iface.InterfaceGuid, TargetSsid))
                        {
                            Console.WriteLine($"[{DateTime.Now:HH:mm:ss}] Wi-Fi OK, nincs teendő.");
                        }
                        else
                        {
                            Console.WriteLine($"[{DateTime.Now:HH:mm:ss}] Wi-Fi leesett, reconnect indul...");
                            TryReconnectToBestAllowedBssid(clientHandle, iface.InterfaceGuid);
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"HIBA: {ex.Message}");
                    }

                    Thread.Sleep(LoopDelayMs);
                }
            }
            finally
            {
                WlanCloseHandle(clientHandle, IntPtr.Zero);
            }
        }

        private static void TryReconnectToBestAllowedBssid(IntPtr clientHandle, Guid ifaceGuid)
        {
            // Friss scan
            ThrowIfError(WlanScan(clientHandle, ref ifaceGuid, IntPtr.Zero, IntPtr.Zero, IntPtr.Zero), "WlanScan");
            Thread.Sleep(1500);

            var visible = GetVisibleBssEntries(clientHandle, ifaceGuid, TargetSsid);

            var best = visible
                .Where(x => _allowed.Contains(NormalizeMac(x.BssidString)))
                .Where(x => x.Rssi >= MinRssiToUse)
                .OrderByDescending(x => x.Rssi)
                .FirstOrDefault();

            if (best == null)
            {
                Console.WriteLine($"[{DateTime.Now:HH:mm:ss}] A megadott BSSID listából most semmi nem elérhető.");
                return;
            }

            Console.WriteLine($"[{DateTime.Now:HH:mm:ss}] Legjobb elérhető BSSID: {best.BssidString}, RSSI={best.Rssi}");
            ConnectToSpecificBssid(clientHandle, ifaceGuid, WifiProfileName, TargetSsid, best.BssidBytes);

            Thread.Sleep(RetryDelayMs);

            if (IsConnectedToTargetWifi(clientHandle, ifaceGuid, TargetSsid))
            {
                Console.WriteLine($"[{DateTime.Now:HH:mm:ss}] Sikeres visszacsatlakozás.");
            }
            else
            {
                Console.WriteLine($"[{DateTime.Now:HH:mm:ss}] A reconnect nem sikerült.");
            }
        }

        private static bool IsConnectedToTargetWifi(IntPtr clientHandle, Guid ifaceGuid, string expectedSsid)
        {
            IntPtr dataPtr = IntPtr.Zero;

            try
            {
                uint dataSize;
                WLAN_OPCODE_VALUE_TYPE opcode;

                uint ret = WlanQueryInterface(
                    clientHandle,
                    ref ifaceGuid,
                    WLAN_INTF_OPCODE.wlan_intf_opcode_current_connection,
                    IntPtr.Zero,
                    out dataSize,
                    out dataPtr,
                    out opcode);

                if (ret != 0 || dataPtr == IntPtr.Zero)
                    return false;

                var conn = Marshal.PtrToStructure<WLAN_CONNECTION_ATTRIBUTES>(dataPtr);

                if (conn.isState != WLAN_INTERFACE_STATE.wlan_interface_state_connected)
                    return false;

                string currentSsid = GetStringFromSsid(conn.wlanAssociationAttributes.dot11Ssid);
                return string.Equals(currentSsid, expectedSsid, StringComparison.Ordinal);
            }
            finally
            {
                if (dataPtr != IntPtr.Zero)
                    WlanFreeMemory(dataPtr);
            }
        }

        private static WLAN_INTERFACE_INFO GetFirstWifiInterface(IntPtr clientHandle)
        {
            IntPtr listPtr;
            ThrowIfError(WlanEnumInterfaces(clientHandle, IntPtr.Zero, out listPtr), "WlanEnumInterfaces");

            try
            {
                var header = Marshal.PtrToStructure<WLAN_INTERFACE_INFO_LIST_HEADER>(listPtr);
                if (header.dwNumberOfItems == 0)
                    throw new Exception("Nem található Wi-Fi interface.");

                IntPtr itemPtr = listPtr + Marshal.SizeOf<WLAN_INTERFACE_INFO_LIST_HEADER>();
                return Marshal.PtrToStructure<WLAN_INTERFACE_INFO>(itemPtr);
            }
            finally
            {
                WlanFreeMemory(listPtr);
            }
        }

        private static List<BssCandidate> GetVisibleBssEntries(IntPtr clientHandle, Guid ifaceGuid, string ssid)
        {
            var result = new List<BssCandidate>();

            IntPtr ssidPtr = IntPtr.Zero;
            IntPtr bssListPtr = IntPtr.Zero;

            try
            {
                var dot11Ssid = CreateDot11Ssid(ssid);
                ssidPtr = Marshal.AllocHGlobal(Marshal.SizeOf<DOT11_SSID>());
                Marshal.StructureToPtr(dot11Ssid, ssidPtr, false);

                uint ret = WlanGetNetworkBssList(
                    clientHandle,
                    ref ifaceGuid,
                    ssidPtr,
                    DOT11_BSS_TYPE.dot11_BSS_type_infrastructure,
                    false,
                    IntPtr.Zero,
                    out bssListPtr);

                ThrowIfError(ret, "WlanGetNetworkBssList");

                var header = Marshal.PtrToStructure<WLAN_BSS_LIST_HEADER>(bssListPtr);
                IntPtr entryPtr = bssListPtr + Marshal.SizeOf<WLAN_BSS_LIST_HEADER>();

                for (int i = 0; i < header.dwNumberOfItems; i++)
                {
                    var entry = Marshal.PtrToStructure<WLAN_BSS_ENTRY>(entryPtr);

                    string entrySsid = GetStringFromSsid(entry.dot11Ssid);
                    if (string.Equals(entrySsid, ssid, StringComparison.Ordinal))
                    {
                        byte[] mac = entry.dot11Bssid;
                        string macStr = BitConverter.ToString(mac).Replace('-', ':');

                        result.Add(new BssCandidate
                        {
                            Ssid = entrySsid,
                            BssidBytes = mac,
                            BssidString = macStr,
                            Rssi = entry.lRssi,
                            LinkQuality = entry.uLinkQuality
                        });
                    }

                    entryPtr += Marshal.SizeOf<WLAN_BSS_ENTRY>();
                }

                return result;
            }
            finally
            {
                if (ssidPtr != IntPtr.Zero) Marshal.FreeHGlobal(ssidPtr);
                if (bssListPtr != IntPtr.Zero) WlanFreeMemory(bssListPtr);
            }
        }

        private static void ConnectToSpecificBssid(IntPtr clientHandle, Guid ifaceGuid, string profileName, string ssid, byte[] bssid)
        {
            IntPtr ssidPtr = IntPtr.Zero;
            IntPtr bssidListPtr = IntPtr.Zero;

            try
            {
                var dot11Ssid = CreateDot11Ssid(ssid);
                ssidPtr = Marshal.AllocHGlobal(Marshal.SizeOf<DOT11_SSID>());
                Marshal.StructureToPtr(dot11Ssid, ssidPtr, false);

                bssidListPtr = BuildSingleBssidList(bssid);

                var parameters = new WLAN_CONNECTION_PARAMETERS
                {
                    wlanConnectionMode = WLAN_CONNECTION_MODE.wlan_connection_mode_profile,
                    strProfile = profileName,
                    pDot11Ssid = ssidPtr,
                    pDesiredBssidList = bssidListPtr,
                    dot11BssType = DOT11_BSS_TYPE.dot11_BSS_type_infrastructure,
                    dwFlags = 0
                };

                ThrowIfError(WlanConnect(clientHandle, ref ifaceGuid, ref parameters, IntPtr.Zero), "WlanConnect");
            }
            finally
            {
                if (ssidPtr != IntPtr.Zero) Marshal.FreeHGlobal(ssidPtr);
                if (bssidListPtr != IntPtr.Zero) Marshal.FreeHGlobal(bssidListPtr);
            }
        }

        private static DOT11_SSID CreateDot11Ssid(string ssid)
        {
            byte[] bytes = Encoding.ASCII.GetBytes(ssid);

            var dot11 = new DOT11_SSID
            {
                uSSIDLength = (uint)bytes.Length,
                ucSSID = new byte[32]
            };

            Array.Copy(bytes, dot11.ucSSID, bytes.Length);
            return dot11;
        }

        private static string GetStringFromSsid(DOT11_SSID ssid)
        {
            return Encoding.ASCII.GetString(ssid.ucSSID, 0, (int)ssid.uSSIDLength);
        }

        private static IntPtr BuildSingleBssidList(byte[] mac)
        {
            if (mac == null || mac.Length != 6)
                throw new ArgumentException("A BSSID 6 byte kell legyen.");

            int size = 4 + 4 + 4 + 6;
            IntPtr ptr = Marshal.AllocHGlobal(size);

            for (int i = 0; i < size; i++)
                Marshal.WriteByte(ptr, i, 0);

            Marshal.WriteByte(ptr, 0, 0x80);
            Marshal.WriteByte(ptr, 1, 1);
            Marshal.WriteInt16(ptr, 2, (short)size);

            Marshal.WriteInt32(ptr, 4, 1);
            Marshal.WriteInt32(ptr, 8, 1);

            for (int i = 0; i < 6; i++)
                Marshal.WriteByte(ptr, 12 + i, mac[i]);

            return ptr;
        }

        private static string NormalizeMac(string mac)
        {
            return mac.Trim().Replace("-", ":").ToUpperInvariant();
        }

        private static void ThrowIfError(uint code, string api)
        {
            if (code != 0)
                throw new Exception($"{api} hiba. Kód: {code}");
        }

        private sealed class BssCandidate
        {
            public string Ssid { get; set; } = "";
            public byte[] BssidBytes { get; set; } = Array.Empty<byte>();
            public string BssidString { get; set; } = "";
            public int Rssi { get; set; }
            public uint LinkQuality { get; set; }
        }

        [DllImport("wlanapi.dll")]
        private static extern uint WlanOpenHandle(
            uint dwClientVersion,
            IntPtr pReserved,
            out uint pdwNegotiatedVersion,
            out IntPtr phClientHandle);

        [DllImport("wlanapi.dll")]
        private static extern uint WlanCloseHandle(
            IntPtr hClientHandle,
            IntPtr pReserved);

        [DllImport("wlanapi.dll")]
        private static extern void WlanFreeMemory(IntPtr pMemory);

        [DllImport("wlanapi.dll")]
        private static extern uint WlanEnumInterfaces(
            IntPtr hClientHandle,
            IntPtr pReserved,
            out IntPtr ppInterfaceList);

        [DllImport("wlanapi.dll", CharSet = CharSet.Unicode)]
        private static extern uint WlanGetNetworkBssList(
            IntPtr hClientHandle,
            ref Guid pInterfaceGuid,
            IntPtr pDot11Ssid,
            DOT11_BSS_TYPE dot11BssType,
            [MarshalAs(UnmanagedType.Bool)] bool bSecurityEnabled,
            IntPtr pReserved,
            out IntPtr ppWlanBssList);

        [DllImport("wlanapi.dll", CharSet = CharSet.Unicode)]
        private static extern uint WlanConnect(
            IntPtr hClientHandle,
            ref Guid pInterfaceGuid,
            ref WLAN_CONNECTION_PARAMETERS pConnectionParameters,
            IntPtr pReserved);

        [DllImport("wlanapi.dll")]
        private static extern uint WlanScan(
            IntPtr hClientHandle,
            ref Guid pInterfaceGuid,
            IntPtr pDot11Ssid,
            IntPtr pIeData,
            IntPtr pReserved);

        [DllImport("wlanapi.dll")]
        private static extern uint WlanQueryInterface(
            IntPtr hClientHandle,
            ref Guid pInterfaceGuid,
            WLAN_INTF_OPCODE OpCode,
            IntPtr pReserved,
            out uint pdwDataSize,
            out IntPtr ppData,
            out WLAN_OPCODE_VALUE_TYPE pWlanOpcodeValueType);

        [StructLayout(LayoutKind.Sequential)]
        private struct WLAN_INTERFACE_INFO_LIST_HEADER
        {
            public int dwNumberOfItems;
            public int dwIndex;
        }

        [StructLayout(LayoutKind.Sequential, CharSet = CharSet.Unicode)]
        private struct WLAN_INTERFACE_INFO
        {
            public Guid InterfaceGuid;

            [MarshalAs(UnmanagedType.ByValTStr, SizeConst = 256)]
            public string strInterfaceDescription;

            public WLAN_INTERFACE_STATE isState;
        }

        private enum WLAN_INTERFACE_STATE
        {
            wlan_interface_state_not_ready = 0,
            wlan_interface_state_connected = 1,
            wlan_interface_state_ad_hoc_network_formed = 2,
            wlan_interface_state_disconnecting = 3,
            wlan_interface_state_disconnected = 4,
            wlan_interface_state_associating = 5,
            wlan_interface_state_discovering = 6,
            wlan_interface_state_authenticating = 7
        }

        [StructLayout(LayoutKind.Sequential)]
        private struct WLAN_BSS_LIST_HEADER
        {
            public uint dwTotalSize;
            public uint dwNumberOfItems;
        }

        [StructLayout(LayoutKind.Sequential)]
        private struct DOT11_SSID
        {
            public uint uSSIDLength;

            [MarshalAs(UnmanagedType.ByValArray, SizeConst = 32)]
            public byte[] ucSSID;
        }

        private enum DOT11_BSS_TYPE : uint
        {
            dot11_BSS_type_infrastructure = 1,
            dot11_BSS_type_independent = 2,
            dot11_BSS_type_any = 3
        }

        [StructLayout(LayoutKind.Sequential)]
        private struct WLAN_RATE_SET
        {
            public uint uRateSetLength;

            [MarshalAs(UnmanagedType.ByValArray, SizeConst = 126)]
            public ushort[] usRateSet;
        }

        [StructLayout(LayoutKind.Sequential)]
        private struct WLAN_BSS_ENTRY
        {
            public DOT11_SSID dot11Ssid;
            public uint uPhyId;

            [MarshalAs(UnmanagedType.ByValArray, SizeConst = 6)]
            public byte[] dot11Bssid;

            public DOT11_BSS_TYPE dot11BssType;
            public DOT11_PHY_TYPE dot11BssPhyType;
            public int lRssi;
            public uint uLinkQuality;
            [MarshalAs(UnmanagedType.Bool)]
            public bool bInRegDomain;
            public ushort usBeaconPeriod;
            public ulong ullTimestamp;
            public ulong ullHostTimestamp;
            public ushort usCapabilityInformation;
            public uint ulChCenterFrequency;
            public WLAN_RATE_SET wlanRateSet;
            public uint ulIeOffset;
            public uint ulIeSize;
        }

        private enum DOT11_PHY_TYPE : uint
        {
            dot11_phy_type_unknown = 0,
            dot11_phy_type_any = 0xFFFFFFFF
        }

        [StructLayout(LayoutKind.Sequential, CharSet = CharSet.Unicode)]
        private struct WLAN_CONNECTION_PARAMETERS
        {
            public WLAN_CONNECTION_MODE wlanConnectionMode;

            [MarshalAs(UnmanagedType.LPWStr)]
            public string strProfile;

            public IntPtr pDot11Ssid;
            public IntPtr pDesiredBssidList;
            public DOT11_BSS_TYPE dot11BssType;
            public uint dwFlags;
        }

        private enum WLAN_CONNECTION_MODE
        {
            wlan_connection_mode_profile = 0,
            wlan_connection_mode_temporary_profile,
            wlan_connection_mode_discovery_secure,
            wlan_connection_mode_discovery_unsecure,
            wlan_connection_mode_auto,
            wlan_connection_mode_invalid
        }

        private enum WLAN_INTF_OPCODE
        {
            wlan_intf_opcode_autoconf_enabled = 1,
            wlan_intf_opcode_background_scan_enabled = 2,
            wlan_intf_opcode_media_streaming_mode = 3,
            wlan_intf_opcode_radio_state = 4,
            wlan_intf_opcode_bss_type = 5,
            wlan_intf_opcode_interface_state = 6,
            wlan_intf_opcode_current_connection = 7
        }

        private enum WLAN_OPCODE_VALUE_TYPE
        {
            query_only = 0,
            set_by_group_policy = 1,
            set_by_user = 2,
            invalid = 3
        }

        [StructLayout(LayoutKind.Sequential)]
        private struct WLAN_CONNECTION_ATTRIBUTES
        {
            public WLAN_INTERFACE_STATE isState;
            public WLAN_CONNECTION_MODE wlanConnectionMode;

            [MarshalAs(UnmanagedType.ByValTStr, SizeConst = 256)]
            public string strProfileName;

            public WLAN_ASSOCIATION_ATTRIBUTES wlanAssociationAttributes;
            public WLAN_SECURITY_ATTRIBUTES wlanSecurityAttributes;
        }

        [StructLayout(LayoutKind.Sequential)]
        private struct WLAN_ASSOCIATION_ATTRIBUTES
        {
            public DOT11_SSID dot11Ssid;
            public DOT11_BSS_TYPE dot11BssType;

            [MarshalAs(UnmanagedType.ByValArray, SizeConst = 6)]
            public byte[] dot11Bssid;

            public DOT11_PHY_TYPE dot11PhyType;
            public uint uDot11PhyIndex;
            public uint wlanSignalQuality;
            public uint ulRxRate;
            public uint ulTxRate;
        }

        [StructLayout(LayoutKind.Sequential)]
        private struct WLAN_SECURITY_ATTRIBUTES
        {
            [MarshalAs(UnmanagedType.Bool)]
            public bool bSecurityEnabled;
            [MarshalAs(UnmanagedType.Bool)]
            public bool bOneXEnabled;
            public uint dot11AuthAlgorithm;
            public uint dot11CipherAlgorithm;
        }
