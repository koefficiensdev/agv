using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.Globalization;
using System.IO;
using System.Linq;
using System.Runtime.InteropServices;
using System.Text;
using System.Threading;

class Program
{
    // =========================
    // BEÁLLÍTÁSOK
    // =========================

    static string LogRoot = @"C:\Logs";

    // Ugyanaz az SSID minden AP-n
    static string Ssid = "AGV_WIFI";

    // Windows Wi-Fi profil neve
    static string ProfileName = "AGV_WIFI";

    // CSV-ben a node a D oszlopban van => index 3
    static int NodeColumnIndex = 3;

    // Figyelési idő
    static int RefreshMs = 2000;

    // Két connect kérés között minimum ennyi idő teljen el
    static int ConnectCooldownMs = 12000;

    // Segíthet, ha váltás előtt bontjuk a kapcsolatot
    static bool DisconnectBeforeConnect = true;

    // Pontos trigger node-ok: CSAK akkor vált, ha node == ExactNode
    static List<NodeRule> Rules = new List<NodeRule>
    {
        new NodeRule(50, "AA:BB:CC:DD:EE:02"),
        new NodeRule(90, "AA:BB:CC:DD:EE:03"),
        // new NodeRule(120, "AA:BB:CC:DD:EE:04"),
    };

    // =========================
    // BELSŐ ÁLLAPOT
    // =========================

    static int _lastSeenNode = int.MinValue;
    static int _lastTriggeredNode = int.MinValue;
    static DateTime _lastConnectAttemptUtc = DateTime.MinValue;
    static string _lastInfo = "Még nem történt váltás.";

    static void Main()
    {
        Console.Title = "AGV Exact-Node -> BSSID Switcher";

        while (true)
        {
            try
            {
                RunOnce();
            }
            catch (Exception ex)
            {
                Console.Clear();
                Console.WriteLine("Váratlan hiba:");
                Console.WriteLine(ex.ToString());
            }

            Thread.Sleep(RefreshMs);
        }
    }

    static void RunOnce()
    {
        string todayFolder = Path.Combine(LogRoot, DateTime.Now.ToString("yyyy-MM-dd"));

        if (!Directory.Exists(todayFolder))
        {
            Console.Clear();
            Console.WriteLine("Nincs mai mappa:");
            Console.WriteLine(todayFolder);
            Console.WriteLine();
            Console.WriteLine(_lastInfo);
            return;
        }

        string latestFile = GetLatestCsvFile(todayFolder);
        if (string.IsNullOrWhiteSpace(latestFile))
        {
            Console.Clear();
            Console.WriteLine("Nincs CSV a mai mappában.");
            Console.WriteLine(todayFolder);
            Console.WriteLine();
            Console.WriteLine(_lastInfo);
            return;
        }

        string[] lines = ReadAllLinesSafe(latestFile);
        if (lines == null || lines.Length == 0)
        {
            Console.Clear();
            Console.WriteLine("Üres vagy nem olvasható CSV.");
            Console.WriteLine(latestFile);
            Console.WriteLine();
            Console.WriteLine(_lastInfo);
            return;
        }

        string lastLine = LastNonEmptyLine(lines);
        if (string.IsNullOrWhiteSpace(lastLine))
        {
            Console.Clear();
            Console.WriteLine("Nincs utolsó adat sor.");
            Console.WriteLine(latestFile);
            Console.WriteLine();
            Console.WriteLine(_lastInfo);
            return;
        }

        char separator = DetectSeparator(lastLine);
        string[] cols = lastLine.Split(separator);

        if (cols.Length <= NodeColumnIndex)
        {
            Console.Clear();
            Console.WriteLine("A sorban nincs D oszlop.");
            Console.WriteLine(lastLine);
            Console.WriteLine();
            Console.WriteLine(_lastInfo);
            return;
        }

        int node;
        if (!TryParseIntLoose(cols[NodeColumnIndex], out node))
        {
            Console.Clear();
            Console.WriteLine("Nem sikerült node-ot olvasni a D oszlopból.");
            Console.WriteLine("Érték: " + cols[NodeColumnIndex]);
            Console.WriteLine("Sor: " + lastLine);
            Console.WriteLine();
            Console.WriteLine(_lastInfo);
            return;
        }

        string currentBssid = NetshWifi.GetCurrentBssid();
        bool nodeChanged = (_lastSeenNode != node);
        NodeRule exactRule = GetExactRule(node);
        bool cooldownActive = (DateTime.UtcNow - _lastConnectAttemptUtc).TotalMilliseconds < ConnectCooldownMs;

        Console.Clear();
        Console.WriteLine("AGV Exact-Node -> BSSID Switcher");
        Console.WriteLine("================================");
        Console.WriteLine("Idő:                " + DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
        Console.WriteLine("CSV:                " + Path.GetFileName(latestFile));
        Console.WriteLine("Node:               " + node);
        Console.WriteLine("Előző node:         " + (_lastSeenNode == int.MinValue ? "(nincs)" : _lastSeenNode.ToString()));
        Console.WriteLine("Aktuális BSSID:     " + currentBssid);
        Console.WriteLine("SSID:               " + Ssid);
        Console.WriteLine("Profile:            " + ProfileName);
        Console.WriteLine();

        if (exactRule == null)
        {
            Console.WriteLine("Ez a node nincs a trigger listában.");
            Console.WriteLine("Nincs váltás.");
            Console.WriteLine();
            Console.WriteLine(_lastInfo);

            _lastSeenNode = node;
            return;
        }

        string targetBssid = NormalizeMac(exactRule.TargetBssid);
        bool alreadyOnTarget = NormalizeMac(currentBssid) == targetBssid;
        bool alreadyTriggeredThisNode = (_lastTriggeredNode == node);

        Console.WriteLine("Trigger node:       " + exactRule.ExactNode);
        Console.WriteLine("Cél BSSID:          " + targetBssid);
        Console.WriteLine("Node változott:     " + (nodeChanged ? "igen" : "nem"));
        Console.WriteLine("Már cél BSSID-n:    " + (alreadyOnTarget ? "igen" : "nem"));
        Console.WriteLine("Már triggerelve:    " + (alreadyTriggeredThisNode ? "igen" : "nem"));
        Console.WriteLine();

        if (!nodeChanged)
        {
            Console.WriteLine("Ugyanazon a node-on maradt, nincs új trigger.");
            Console.WriteLine(_lastInfo);

            _lastSeenNode = node;
            return;
        }

        if (alreadyTriggeredThisNode)
        {
            Console.WriteLine("Ez a trigger node már le lett kezelve.");
            Console.WriteLine(_lastInfo);

            _lastSeenNode = node;
            return;
        }

        if (alreadyOnTarget)
        {
            _lastInfo = "Nem kellett váltani: már a cél BSSID-n van (" + targetBssid + ").";
            Console.WriteLine(_lastInfo);

            _lastTriggeredNode = node;
            _lastSeenNode = node;
            return;
        }

        if (cooldownActive)
        {
            Console.WriteLine("Cooldown aktív, most nem küldünk új connect kérést.");
            Console.WriteLine(_lastInfo);

            _lastSeenNode = node;
            return;
        }

        string info;
        bool ok = WifiNative.TryConnectToSpecificBssid(
            Ssid,
            ProfileName,
            targetBssid,
            DisconnectBeforeConnect,
            out info);

        _lastConnectAttemptUtc = DateTime.UtcNow;

        if (ok)
        {
            _lastTriggeredNode = node;
            _lastInfo = "Váltás elküldve -> node " + node + " -> " + targetBssid + " | " + info;
            Console.WriteLine("VÁLTÁS ELKÜLDVE");
            Console.WriteLine(_lastInfo);
        }
        else
        {
            _lastInfo = "Váltás hiba -> node " + node + " -> " + targetBssid + " | " + info;
            Console.WriteLine("VÁLTÁS HIBA");
            Console.WriteLine(_lastInfo);
        }

        _lastSeenNode = node;

        Console.WriteLine();
        Console.WriteLine("Trigger szabályok:");
        foreach (var r in Rules)
        {
            Console.WriteLine("  node == " + r.ExactNode + " -> " + NormalizeMac(r.TargetBssid));
        }
    }

    static NodeRule GetExactRule(int node)
    {
        for (int i = 0; i < Rules.Count; i++)
        {
            if (Rules[i].ExactNode == node)
                return Rules[i];
        }
        return null;
    }

    static string GetLatestCsvFile(string folder)
    {
        try
        {
            return Directory.GetFiles(folder, "*.csv")
                .OrderByDescending(f =>
                {
                    try
                    {
                        return File.GetLastWriteTime(f);
                    }
                    catch
                    {
                        return DateTime.MinValue;
                    }
                })
                .FirstOrDefault();
        }
        catch
        {
            return null;
        }
    }

    static string[] ReadAllLinesSafe(string path)
    {
        using (var fs = new FileStream(path, FileMode.Open, FileAccess.Read, FileShare.ReadWrite))
        using (var sr = new StreamReader(fs))
        {
            var list = new List<string>();
            while (!sr.EndOfStream)
            {
                list.Add(sr.ReadLine());
            }
            return list.ToArray();
        }
    }

    static string LastNonEmptyLine(string[] lines)
    {
        if (lines == null) return null;

        for (int i = lines.Length - 1; i >= 0; i--)
        {
            if (!string.IsNullOrWhiteSpace(lines[i]))
                return lines[i];
        }

        return null;
    }

    static char DetectSeparator(string line)
    {
        if (string.IsNullOrWhiteSpace(line))
            return ',';

        int semis = line.Count(c => c == ';');
        int commas = line.Count(c => c == ',');
        return semis > commas ? ';' : ',';
    }

    static bool TryParseIntLoose(string text, out int value)
    {
        value = 0;

        if (string.IsNullOrWhiteSpace(text))
            return false;

        text = text.Trim().Trim('"');

        int iv;
        if (int.TryParse(text, NumberStyles.Integer, CultureInfo.InvariantCulture, out iv))
        {
            value = iv;
            return true;
        }

        double dv;
        if (double.TryParse(text.Replace(',', '.'), NumberStyles.Any, CultureInfo.InvariantCulture, out dv))
        {
            value = (int)Math.Round(dv);
            return true;
        }

        return false;
    }

    static string NormalizeMac(string mac)
    {
        if (string.IsNullOrWhiteSpace(mac))
            return "";

        return mac.Trim().ToUpperInvariant().Replace("-", ":");
    }
}

class NodeRule
{
    public int ExactNode { get; private set; }
    public string TargetBssid { get; private set; }

    public NodeRule(int exactNode, string targetBssid)
    {
        ExactNode = exactNode;
        TargetBssid = targetBssid ?? "";
    }
}

static class NetshWifi
{
    public static string GetCurrentBssid()
    {
        try
        {
            ProcessStartInfo psi = new ProcessStartInfo();
            psi.FileName = "netsh";
            psi.Arguments = "wlan show interfaces";
            psi.UseShellExecute = false;
            psi.RedirectStandardOutput = true;
            psi.RedirectStandardError = true;
            psi.CreateNoWindow = true;
            psi.StandardOutputEncoding = Encoding.UTF8;

            using (Process p = Process.Start(psi))
            {
                string output = p.StandardOutput.ReadToEnd();
                p.WaitForExit();

                if (string.IsNullOrWhiteSpace(output))
                    return "(nem olvasható)";

                string bssid = ParseBssid(output);
                if (!string.IsNullOrWhiteSpace(bssid))
                    return bssid;

                return "(nincs csatlakozás / nincs BSSID)";
            }
        }
        catch
        {
            return "(netsh hiba)";
        }
    }

    static string ParseBssid(string output)
    {
        string[] lines = output
            .Split(new[] { "\r\n", "\n" }, StringSplitOptions.None);

        foreach (string raw in lines)
        {
            if (raw == null)
                continue;

            string line = raw.Trim();

            if (line.StartsWith("BSSID", StringComparison.OrdinalIgnoreCase))
            {
                int idx = line.IndexOf(':');
                if (idx >= 0 && idx + 1 < line.Length)
                    return line.Substring(idx + 1).Trim();
            }
        }

        return "";
    }
}

static class WifiNative
{
    public static bool TryConnectToSpecificBssid(
        string ssid,
        string profileName,
        string targetBssid,
        bool disconnectBeforeConnect,
        out string info)
    {
        info = "";

        IntPtr client = IntPtr.Zero;
        IntPtr ifListPtr = IntPtr.Zero;
        IntPtr ssidPtr = IntPtr.Zero;
        IntPtr desiredBssidListPtr = IntPtr.Zero;

        try
        {
            uint negotiatedVersion;
            Check(WlanOpenHandle(2, IntPtr.Zero, out negotiatedVersion, out client), "WlanOpenHandle");

            Guid ifGuid = GetFirstInterfaceGuid(client, out ifListPtr);
            DOT11_SSID ssidStruct = MakeSsid(ssid);

            try
            {
                WlanScan(client, ref ifGuid, ref ssidStruct, IntPtr.Zero, IntPtr.Zero);
                Thread.Sleep(800);
            }
            catch
            {
            }

            if (disconnectBeforeConnect)
            {
                try
                {
                    WlanDisconnect(client, ref ifGuid, IntPtr.Zero);
                    Thread.Sleep(800);
                }
                catch
                {
                }
            }

            ssidPtr = Marshal.AllocHGlobal(Marshal.SizeOf(typeof(DOT11_SSID)));
            Marshal.StructureToPtr(ssidStruct, ssidPtr, false);

            desiredBssidListPtr = AllocSingleBssidList(ParseMac(targetBssid));

            WLAN_CONNECTION_PARAMETERS cp = new WLAN_CONNECTION_PARAMETERS();
            cp.wlanConnectionMode = WLAN_CONNECTION_MODE.wlan_connection_mode_profile;
            cp.strProfile = profileName;
            cp.pDot11Ssid = ssidPtr;
            cp.pDesiredBssidList = desiredBssidListPtr;
            cp.dot11BssType = DOT11_BSS_TYPE.dot11_BSS_type_infrastructure;
            cp.dwFlags = 0;

            Check(WlanConnect(client, ref ifGuid, ref cp, IntPtr.Zero), "WlanConnect");

            info = "Connect kérés elküldve a drivernek.";
            return true;
        }
        catch (Exception ex)
        {
            info = ex.Message;
            return false;
        }
        finally
        {
            if (desiredBssidListPtr != IntPtr.Zero) Marshal.FreeHGlobal(desiredBssidListPtr);
            if (ssidPtr != IntPtr.Zero) Marshal.FreeHGlobal(ssidPtr);
            if (ifListPtr != IntPtr.Zero) WlanFreeMemory(ifListPtr);
            if (client != IntPtr.Zero) WlanCloseHandle(client, IntPtr.Zero);
        }
    }

    static Guid GetFirstInterfaceGuid(IntPtr client, out IntPtr ifListPtr)
    {
        ifListPtr = IntPtr.Zero;

        Check(WlanEnumInterfaces(client, IntPtr.Zero, out ifListPtr), "WlanEnumInterfaces");

        int numberOfItems = Marshal.ReadInt32(ifListPtr, 0);
        if (numberOfItems < 1)
            throw new Exception("Nem található Wi-Fi interface.");

        long current = ifListPtr.ToInt64() + 8;
        WLAN_INTERFACE_INFO info = (WLAN_INTERFACE_INFO)Marshal.PtrToStructure(
            new IntPtr(current),
            typeof(WLAN_INTERFACE_INFO));

        return info.InterfaceGuid;
    }

    static DOT11_SSID MakeSsid(string ssid)
    {
        byte[] bytes = Encoding.ASCII.GetBytes(ssid);
        if (bytes.Length > 32)
            throw new Exception("Az SSID túl hosszú.");

        DOT11_SSID s = new DOT11_SSID();
        s.uSSIDLength = (uint)bytes.Length;
        s.ucSSID = new byte[32];
        Array.Clear(s.ucSSID, 0, s.ucSSID.Length);
        Array.Copy(bytes, s.ucSSID, bytes.Length);
        return s;
    }

    static byte[] ParseMac(string mac)
    {
        string[] parts = (mac ?? "")
            .Trim()
            .ToUpperInvariant()
            .Replace("-", ":")
            .Split(':');

        if (parts.Length != 6)
            throw new Exception("Hibás MAC/BSSID formátum: " + mac);

        byte[] bytes = new byte[6];
        for (int i = 0; i < 6; i++)
        {
            bytes[i] = byte.Parse(parts[i], NumberStyles.HexNumber, CultureInfo.InvariantCulture);
        }

        return bytes;
    }

    static IntPtr AllocSingleBssidList(byte[] mac)
    {
        IntPtr ptr = Marshal.AllocHGlobal(24);

        for (int i = 0; i < 24; i++)
            Marshal.WriteByte(ptr, i, 0);

        Marshal.WriteByte(ptr, 0, 1);
        Marshal.WriteByte(ptr, 1, 1);
        Marshal.WriteInt16(ptr, 2, 12);

        Marshal.WriteInt32(ptr, 4, 1);
        Marshal.WriteInt32(ptr, 8, 1);

        for (int i = 0; i < 6; i++)
            Marshal.WriteByte(ptr, 12 + i, mac[i]);

        return ptr;
    }

    static void Check(uint result, string api)
    {
        if (result != 0)
            throw new Exception(api + " hiba. Win32 kód: " + result);
    }

    [DllImport("wlanapi.dll")]
    static extern uint WlanOpenHandle(
        uint dwClientVersion,
        IntPtr pReserved,
        out uint pdwNegotiatedVersion,
        out IntPtr phClientHandle);

    [DllImport("wlanapi.dll")]
    static extern uint WlanCloseHandle(
        IntPtr hClientHandle,
        IntPtr pReserved);

    [DllImport("wlanapi.dll")]
    static extern uint WlanEnumInterfaces(
        IntPtr hClientHandle,
        IntPtr pReserved,
        out IntPtr ppInterfaceList);

    [DllImport("wlanapi.dll")]
    static extern void WlanFreeMemory(
        IntPtr pMemory);

    [DllImport("wlanapi.dll")]
    static extern uint WlanDisconnect(
        IntPtr hClientHandle,
        ref Guid pInterfaceGuid,
        IntPtr pReserved);

    [DllImport("wlanapi.dll")]
    static extern uint WlanScan(
        IntPtr hClientHandle,
        ref Guid pInterfaceGuid,
        ref DOT11_SSID pDot11Ssid,
        IntPtr pIeData,
        IntPtr pReserved);

    [DllImport("wlanapi.dll", CharSet = CharSet.Unicode)]
    static extern uint WlanConnect(
        IntPtr hClientHandle,
        ref Guid pInterfaceGuid,
        ref WLAN_CONNECTION_PARAMETERS pConnectionParameters,
        IntPtr pReserved);
}

enum WLAN_CONNECTION_MODE
{
    wlan_connection_mode_profile = 0,
    wlan_connection_mode_temporary_profile = 1,
    wlan_connection_mode_discovery_secure = 2,
    wlan_connection_mode_discovery_unsecure = 3,
    wlan_connection_mode_auto = 4,
    wlan_connection_mode_invalid = 5
}

enum DOT11_BSS_TYPE
{
    dot11_BSS_type_infrastructure = 1,
    dot11_BSS_type_independent = 2,
    dot11_BSS_type_any = 3
}

enum WLAN_INTERFACE_STATE
{
    wlan_interface_state_not_ready = 0,
    wlan_interface_state_connected = 1,
    wlan_interface_state_ad_hoc_network_formed = 2,
    wlan_interface_state_disconnecting = 3,
    wlan_interface_state_disconnected = 4,
    wlan_interface_state_associating = 5,
    wlan_interface_state_discovering = 6,
    wlan_interface_state_authenticating = 7
}

[StructLayout(LayoutKind.Sequential, CharSet = CharSet.Unicode)]
struct WLAN_INTERFACE_INFO
{
    public Guid InterfaceGuid;

    [MarshalAs(UnmanagedType.ByValTStr, SizeConst = 256)]
    public string strInterfaceDescription;

    public WLAN_INTERFACE_STATE isState;
}

[StructLayout(LayoutKind.Sequential)]
struct DOT11_SSID
{
    public uint uSSIDLength;

    [MarshalAs(UnmanagedType.ByValArray, SizeConst = 32)]
    public byte[] ucSSID;
}

[StructLayout(LayoutKind.Sequential, CharSet = CharSet.Unicode)]
struct WLAN_CONNECTION_PARAMETERS
{
    public WLAN_CONNECTION_MODE wlanConnectionMode;

    [MarshalAs(UnmanagedType.LPWStr)]
    public string strProfile;

    public IntPtr pDot11Ssid;
    public IntPtr pDesiredBssidList;
    public DOT11_BSS_TYPE dot11BssType;
    public uint dwFlags;
}